# Tradbot Environment Configuration
# Copy to .env and fill in your actual values
# WARNING: Never commit .env to version control

# Flattrade Credentials (REQUIRED)
FLATTRADE_USER=your_username
FLATTRADE_PASSWORD=your_password
FLATTRADE_API_KEY=your_api_key
FLATTRADE_API_SECRET=your_api_secret

# Logging Configuration
LOG_LEVEL=INFO              # [DEBUG, INFO, WARNING, ERROR, CRITICAL]
LOG_DIR=/logs              # Directory for log files

# Database Configuration
LOG_DB_PATH=/data/trades.db # SQLite database location
STATE_FILE_PATH=/data/state.json  # persistent state file

# Trading Configuration
DRY_RUN=false              # Set true to test without real orders
MAX_CAPITAL_PER_TRADE=0.35 # 35% of account per trade
DAILY_LOSS_LIMIT=-0.02     # -2% triggers disable
MAX_TRADES_PER_DAY=2       # Max 2 trades daily

# Broker Configuration
BROKER_API_BASE=https://api.flattrade.com
BROKER_WS_URL=wss://feed.pxl.finvasia.com/ws

# Optional: Advanced Settings
# Uncomment to override defaults from config/settings.py
# VIX_THRESHOLD_TRENDING=12
# ENTRY_OPEN_HOUR=9
# ENTRY_OPEN_MINUTE=45
# ENTRY_CLOSE_HOUR=13
# ENTRY_CLOSE_MINUTE=30
